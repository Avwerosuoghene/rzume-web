{
  "name": "rzume-web",
  "version": "0.0.0",
  "scripts": {
    "ng": "ng",
    "start": "ng serve",
    "start-proxy": "ng serve --proxy-config proxy.conf.json",
    "build": "ng build",
    "build:prod": "ng build --configuration production",
    "watch": "ng build --watch --configuration development",
    "test": "ng test",
    "test:ci": "ng test --watch=false --browsers=ChromeHeadless --code-coverage",
    "test:coverage": "ng test --code-coverage",
    "cy:open": "cypress open",
    "analyze-bundle": "ng build --configuration=analyze-bundle && source-map-explorer dist/**/*.js --no-border-checks",
    "optimize-images": "chmod +x ./scripts/optimize-images.sh && ./scripts/optimize-images.sh",
    "prepare": "husky install",
    "update-docs": "node scripts/update-docs.js",
    "quality-gate:full": "chmod +x ./scripts/quality-gate-check.sh && ./scripts/quality-gate-check.sh",
    "quality-gate:automated": "npm run type-check && npm run security:audit",
    "type-check": "tsc --noEmit",
    "lint": "ng lint",
    "security:audit": "npm audit --audit-level=high",
    "security:scan": "chmod +x ./scripts/security-scan.sh && ./scripts/security-scan.sh",
    "security:fix": "chmod +x ./scripts/security-fix.sh && ./scripts/security-fix.sh",
    "security:audit-prod": "npm audit --omit=dev"
  },
  "private": true,
  "dependencies": {
    "@abacritt/angularx-social-login": "^2.3.0",
    "@angular/animations": "^18.2.0",
    "@angular/cdk": "^18.2.0",
    "@angular/common": "^18.2.0",
    "@angular/compiler": "^18.2.0",
    "@angular/core": "^18.2.0",
    "@angular/forms": "^18.2.0",
    "@angular/material": "^18.2.0",
    "@angular/platform-browser": "^18.2.0",
    "@angular/platform-browser-dynamic": "^18.2.0",
    "@angular/router": "^18.2.0",
    "@auth0/angular-jwt": "^5.2.0",
    "@types/google-one-tap": "^1.2.6",
    "google-auth-library": "^9.13.0",
    "jwt-decode": "^4.0.0",
    "mixpanel-browser": "^2.74.0",
    "rxjs": "~7.8.0",
    "tslib": "^2.3.0",
    "zone.js": "~0.14.10"
  },
  "devDependencies": {
    "@angular-devkit/build-angular": "^18.2.0",
    "@angular-eslint/builder": "^18.3.0",
    "@angular-eslint/eslint-plugin": "^18.3.0",
    "@angular-eslint/eslint-plugin-template": "^18.3.0",
    "@angular-eslint/schematics": "^18.3.0",
    "@angular-eslint/template-parser": "^18.3.0",
    "@angular/cli": "^18.2.0",
    "@angular/compiler-cli": "^18.2.0",
    "@playwright/test": "^1.49.0",
    "@types/jasmine": "~5.1.0",
    "@types/mixpanel-browser": "^2.60.0",
    "@types/node": "^22.9.3",
    "@typescript-eslint/eslint-plugin": "^7.16.0",
    "@typescript-eslint/parser": "^7.16.0",
    "cypress": "^13.13.3",
    "eslint": "^8.57.0",
    "husky": "^8.0.3",
    "jasmine-core": "~5.2.0",
    "karma": "~6.4.4",
    "karma-chrome-launcher": "~3.2.0",
    "karma-coverage": "~2.2.0",
    "karma-jasmine": "~5.1.0",
    "karma-jasmine-html-reporter": "~2.1.0",
    "sharp-cli": "^4.2.0",
    "source-map-explorer": "^2.5.3",
    "typescript": "~5.5.4"
  },
  "overrides": {
    "cross-spawn": ">=7.0.6",
    "tar": ">=7.5.13",
    "postcss": ">=8.5.10",
    "rollup": ">=4.60.2",
    "serialize-javascript": ">=7.0.5",
    "picomatch": ">=4.0.4",
    "webpack": ">=5.106.2",
    "webpack-dev-server": ">=5.2.3",
    "vite": ">=5.4.21",
    "@babel/runtime": ">=7.29.2",
    "esbuild": ">=0.25.12",
    "http-proxy-middleware": ">=3.0.5",
    "ajv": ">=8.18.0",
    "tmp": ">=0.2.5",
    "uuid": ">=11.1.0"
  }
}
